{
  "name": "tbpro-shared",
  "version": "0.4.4",
  "private": false,
  "type": "module",
  "description": "Shared code for tbpro add-on",
  "main": "src/index",
  "types": "src/index.ts",
  "scripts": {
    "build:shared": "tsc",
    "ci:validate": "pnpm lint:all; pnpm prettier:all; pnpm run test",
    "test": "VITE_TESTING=true vitest run --silent",
    "test-debug": "VITE_TESTING=true vitest --inspect-brk --single-thread",
    "test:watch": "VITE_TESTING=true vitest --watch",
    "lint:all": "pnpx eslint . --fix --ignore-pattern 'dist/*'",
    "prettier:all": "pnpm prettier --write .",
    "postinstall": "pnpm build:shared"
  },
  "dependencies": {
    "@tanstack/vue-query": "catalog:",
    "dayjs": "catalog:",
    "get-random-values": "^3.0.0",
    "oidc-client-ts": "^3.3.0",
    "pinia": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/node": "*",
    "@types/thunderbird-webext-browser": "^127.0.0",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "catalog:",
    "dotenv": "^16.4.7",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.56.1",
    "vite": "catalog:",
    "vitest": "catalog:",
    "webextension-polyfill": "^0.12.0"
  },
  "keywords": [],
  "author": "",
  "license": "MPL-2.0",
  "exports": {
    ".": {
      "import": "./src/index",
      "require": "./src/index"
    },
    "./tsconfig.client.base.json": "./dist/tsconfig.client.base.json"
  }
}